# heartland.io — Apache config for the heartland-rust + GTranslate-proxy origin.
#
# Active languages (18):
#   ar bn de es fr hi it ja ko nl pa pl pt tr ur vi zh-CN
#   (en = main language, served bare without prefix)
#
# Layering:
#   1. GTranslate rewrites first — translated paths route through the PHP proxy
#   2. SPA fallback — anything else not on disk falls through to index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Strip double-language prefixes (e.g. /es/fr/foo → /es/foo). Defense-in-depth
  # against a Google-translated translated page leaking back as a URL.
  RewriteRule ^(ar|bn|de|es|fr|hi|it|ja|ko|nl|pa|pl|pt|tr|ur|vi|zh-CN)/(ar|bn|de|es|fr|hi|it|ja|ko|nl|pa|pl|pt|tr|ur|vi|zh-CN)/(.*)$ /$1/$3 [R=301,L]

  # /<lang>/<path> → GTranslate proxy (only when no physical file matches).
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^(ar|bn|de|es|fr|hi|it|ja|ko|nl|pa|pl|pt|tr|ur|vi|zh-CN)/(.*)$ /gtranslate/gtranslate.php?glang=$1&gurl=$2 [L,QSA]

  # Trailing slash on bare /<lang>.
  RewriteRule ^(ar|bn|de|es|fr|hi|it|ja|ko|nl|pa|pl|pt|tr|ur|vi|zh-CN)$ /$1/ [R=301,L]

  # SPA fallback: client-side router handles unknown English paths.
  # Do NOT rewrite requests targeting the proxy folder or real assets.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/gtranslate/
  RewriteRule ^.*$ /index.html [L]
</IfModule>

# WASM MIME type for Dioxus.
AddType application/wasm .wasm

# gzip / deflate for text content (skip already-compressed binaries).
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/xml application/json application/javascript application/wasm image/svg+xml
</IfModule>

# Long-cache hashed assets; short-cache HTML.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 5 minutes"
  ExpiresByType application/wasm "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Belt-and-suspenders: hide config from web fetches.
<FilesMatch "(config\.php|cacert\.pem|debug\.txt)$">
  Require all denied
</FilesMatch>
