# Analytics & tracking — set at BUILD time, not runtime.
#
# Usage:
#   HEARTLAND_GA_ID=G-XXXXXXXXXX dx build --release --platform web
#
# Or copy this file to `.env` (gitignored) and source it before `dx build`:
#   set -a; source .env; set +a; dx build --release --platform web
#
# Unset = compiled out, zero runtime cost. Each ID is public (it ships in
# the page source for any visitor to read), so these are not secrets — just
# environment-specific config.

# Google Analytics 4 — current production ID. Accepts one ID or a
# comma-separated list to fire on multiple GA4 properties at once
# (e.g. dual-track during a property migration).
#   HEARTLAND_GA_ID=G-CFVBK0N6L6
#   HEARTLAND_GA_ID=G-OLD,G-NEW
HEARTLAND_GA_ID=G-CFVBK0N6L6

# HubSpot — drives form embeds (hbspt.forms.create) + visitor analytics.
# Numeric Hub / Portal ID visible in the HubSpot dashboard URL.
HEARTLAND_HUBSPOT_HUB_ID=8084764

# Google Tag Manager (head + body noscript fallback)
# HEARTLAND_GTM_ID=GTM-XXXXXXX

# Google Search Console — domain ownership verification. Issued by Search
# Console (Settings → Ownership verification → HTML tag), copy the value
# from `content="..."`. Not a tracker; just proves the domain is yours.
# HEARTLAND_GOOGLE_VERIFICATION=abc123def456

# Site origin — used for canonical URLs, sitemap, OG/Twitter, JSON-LD.
HEARTLAND_SITE_ORIGIN=https://heartland.io
